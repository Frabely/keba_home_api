HTTP_BIND=0.0.0.0:65109
STATUS_STATIONS=Carport@192.168.233.99:7090;Eingang@192.168.233.98:7090

# Default allows the local browser frontend during development.
# Add production frontend origins as a comma-separated allow-list when needed.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://invessiv.de
DACHS_F233_BASE_URL=http://192.168.233.91:8080
DACHS_F233_USERNAME=GLT
DACHS_F233_PASSWORD=HECHT
DACHS_F235_BASE_URL=http://192.168.233.92:8080
DACHS_F235_USERNAME=GLT
DACHS_F235_PASSWORD=HECHT

# Optional; API mode no longer requires KEBA_* values
RUST_LOG=info
LOG_FORMAT=compact
