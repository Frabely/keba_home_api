# API reader process uses the same DB file written by keba-home-service
DB_PATH=/var/lib/keba/keba.db
HTTP_BIND=0.0.0.0:8080

# Default '*' keeps the browser API reachable from anywhere until auth lands.
# For a fixed frontend later, set a comma-separated allow-list instead.
CORS_ALLOWED_ORIGINS=*

# Optional; API mode no longer requires KEBA_* values
RUST_LOG=info
LOG_FORMAT=compact
