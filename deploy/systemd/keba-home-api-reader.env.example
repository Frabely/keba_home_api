# API reader process uses the same DB file written by keba-home-service
DB_PATH=/var/lib/keba/keba.db
HTTP_BIND=0.0.0.0:65109

# Default allows the local browser frontend during development.
# Add production frontend origins as a comma-separated allow-list when needed.
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://invessiv.de

# Optional; API mode no longer requires KEBA_* values
RUST_LOG=info
LOG_FORMAT=compact
